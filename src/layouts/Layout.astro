---
interface Props {
	title?: string;
	description?: string;
	lang?: string;
}

const {
	title = "MicYou - Professional Microphone Streaming",
	description = "MicYou - Turn your smartphone into a professional microphone for PC. Low latency, high quality audio streaming via Wi-Fi or USB.",
	lang = "en",
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<link rel="icon" type="image/png" href={`${base}icon.png`} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta
			name="keywords"
			content="microphone, streaming, android microphone, pc audio, low latency, wifi mic, usb mic, MicYou"
		/>
		<meta name="author" content="LanRhyme" />
		<meta name="robots" content="index, follow" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content={`${base}icon.png`} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
