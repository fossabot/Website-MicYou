---
interface Props {
	t: {
		privacy: string;
		terms: string;
		rights: string;
		madeWith: string;
	};
}

const { t } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="footer">
	<div class="footer-container">
		<div class="footer-content">
			<div class="footer-brand">
				<md-icon class="footer-logo">mic</md-icon>
				<span class="brand-name">MicYou</span>
			</div>

			<div class="footer-links">
				<a href="#" class="footer-link">{t.privacy}</a>
				<a href="#" class="footer-link">{t.terms}</a>
				<a
					href="https://github.com/LanRhyme/MicYou"
					target="_blank"
					rel="noopener"
					class="footer-link">GitHub</a
				>
			</div>
		</div>

		<div class="footer-bottom">
			<p>&copy; {currentYear} MicYou. {t.rights}</p>
			<p>{t.madeWith}</p>
		</div>
	</div>
</footer>

<script>
	import "@material/web/icon/icon.js";
</script>

<style>
	.footer {
		background-color: var(--md-sys-color-surface);
		color: var(--md-sys-color-on-surface-variant);
		padding: 64px 24px 32px;
		border-top: 1px solid var(--md-sys-color-outline-variant);
	}

	.footer-container {
		max-width: 1200px;
		margin: 0 auto;
	}

	.footer-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 48px;
		flex-wrap: wrap;
		gap: 24px;
	}

	.footer-brand {
		display: flex;
		align-items: center;
		gap: 8px;
		color: var(--md-sys-color-on-surface);
		font-weight: 700;
		font-size: 20px;
	}

	.footer-logo {
		font-size: 24px;
		color: var(--md-sys-color-primary);
	}

	.footer-links {
		display: flex;
		gap: 24px;
	}

	.footer-link {
		color: var(--md-sys-color-on-surface-variant);
		transition: color 0.2s;
		font-size: 14px;
		text-decoration: none;
	}

	.footer-link:hover {
		color: var(--md-sys-color-primary);
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		font-size: 12px;
		color: var(--md-sys-color-outline);
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		padding-top: 24px;
	}

	@media (max-width: 600px) {
		.footer-content {
			flex-direction: column;
			align-items: flex-start;
		}

		.footer-bottom {
			flex-direction: column;
			gap: 8px;
			align-items: center;
			text-align: center;
		}
	}
</style>
