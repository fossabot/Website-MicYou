---
interface DownloadTranslations {
	recommended: string;
	title: string;
	subtitle: string;
	winClient: string;
	winReq: string;
	macClient: string;
	macReq: string;
	btnWinDownload: string;
	btnWinZip: string;
	linuxClient: string;
	linuxReq: string;
	btnLinuxDebian: string;
	btnLinuxRPM: string;
	btnLinuxAUR: string;
	aurCommandCopied: string;
	loading: string;
	androidApp: string;
	androidReq: string;
	btnApk: string;
	bit64: string;
}

interface Props {
	t: DownloadTranslations;
}

const { t } = Astro.props;
const FALLBACK = "https://github.com/LanRhyme/MicYou/releases/latest";
---

<section id="download" class="download-section" data-t={JSON.stringify(t)}>
	<div class="download-content">
		<h2 class="section-title">{t.title}</h2>
		<p class="section-subtitle">{t.subtitle}</p>

		<div class="download-card">
			<!-- Windows -->
			<div class="download-row" data-platform="windows">
				<div class="platform-info">
					<div class="platform-icon">
						<md-icon>desktop_windows</md-icon>
					</div>
					<div class="platform-text">
						<h3 class="platform-name">{t.winClient}</h3>
						<p class="platform-desc">{t.winReq}</p>
					</div>
				</div>
				<div class="store-buttons">
					<md-outlined-button data-url="exe" href={FALLBACK}>
						<md-icon slot="icon">download</md-icon>
						<span class="btn-label">{t.loading}</span>
					</md-outlined-button>
					<md-outlined-button data-url="zip" href={FALLBACK}>
						<md-icon slot="icon">download</md-icon>
						{t.btnWinZip}
					</md-outlined-button>
				</div>
			</div>

			<!-- Android -->
			<div class="download-row" data-platform="android">
				<div class="platform-info">
					<div class="platform-icon">
						<md-icon>smartphone</md-icon>
					</div>
					<div class="platform-text">
						<h3 class="platform-name">{t.androidApp}</h3>
						<p class="platform-desc">{t.androidReq}</p>
					</div>
				</div>
				<div class="store-buttons">
					<md-outlined-button data-url="apk" href={FALLBACK}>
						<md-icon slot="icon">android</md-icon>
						{t.btnApk}
					</md-outlined-button>
				</div>
			</div>

			<!-- macOS -->
			<div class="download-row" data-platform="mac">
				<div class="platform-info">
					<div class="platform-icon">
						<md-icon>laptop_mac</md-icon>
					</div>
					<div class="platform-text">
						<h3 class="platform-name">{t.macClient}</h3>
						<p class="platform-desc">{t.macReq}</p>
					</div>
				</div>
				<div class="store-buttons">
					<md-outlined-button data-url="dmg-arm" href={FALLBACK}>
						<md-icon slot="icon">download</md-icon>
						Apple Silicon
					</md-outlined-button>
					<md-outlined-button data-url="dmg-x64" href={FALLBACK}>
						<md-icon slot="icon">download</md-icon>
						Intel x64
					</md-outlined-button>
				</div>
			</div>

			<!-- Linux -->
			<div class="download-row" data-platform="linux">
				<div class="platform-info">
					<div class="platform-icon">
						<md-icon>desktop_mac</md-icon>
					</div>
					<div class="platform-text">
						<h3 class="platform-name">{t.linuxClient}</h3>
						<p class="platform-desc">{t.linuxReq}</p>
					</div>
				</div>
				<div class="store-buttons">
					<md-outlined-button data-url="deb" href={FALLBACK}>
						<md-icon slot="icon">download</md-icon>
						{t.btnLinuxDebian}
					</md-outlined-button>
					<md-outlined-button data-url="rpm" href={FALLBACK}>
						<md-icon slot="icon">download</md-icon>
						{t.btnLinuxRPM}
					</md-outlined-button>
					<md-outlined-button data-action="copy-aur">
						<md-icon slot="icon">content_copy</md-icon>
						{t.btnLinuxAUR}
					</md-outlined-button>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	import "../scripts/downloadSection.ts";
</script>

<style>
	.download-section {
		padding: 100px 24px;
		background-color: var(--md-sys-color-background);
		position: relative;
		overflow: hidden;
	}

	.download-content {
		max-width: 900px;
		margin: 0 auto;
		text-align: center;
		position: relative;
		z-index: 2;
	}

	.section-title {
		font-size: 36px;
		font-weight: 700;
		margin-bottom: 16px;
		color: var(--md-sys-color-on-surface);
	}

	.section-subtitle {
		font-size: 18px;
		color: var(--md-sys-color-on-surface-variant);
		margin-bottom: 48px;
		max-width: 600px;
		margin-left: auto;
		margin-right: auto;
	}

	.download-card {
		background: var(--md-sys-color-surface-variant);
		border-radius: 16px;
		padding: 8px;
		border: 1px solid rgba(0, 0, 0, 0.04);
		backdrop-filter: blur(6px) saturate(120%);
		box-shadow: var(--md-sys-elevation-level1);
	}

	.download-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		padding: 20px 24px;
		border-radius: 12px;
		transition: background-color 200ms ease;
	}

	.download-row:hover {
		background: rgba(0, 0, 0, 0.03);
	}

	.download-row:not(:last-child) {
		border-bottom: 1px solid rgba(0, 0, 0, 0.06);
	}

	.download-row.recommended {
		background: color-mix(
			in srgb,
			var(--md-sys-color-surface-variant),
			var(--md-sys-color-primary) 4%
		);
	}

	.platform-info {
		display: flex;
		align-items: center;
		gap: 16px;
		flex-shrink: 0;
	}

	.platform-icon {
		color: var(--md-sys-color-primary);
		width: 48px;
		height: 48px;
		background-color: var(--md-sys-color-secondary-container);
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.platform-icon md-icon {
		--md-icon-size: 28px;
	}

	.platform-text {
		text-align: left;
	}

	.platform-name {
		font-size: 18px;
		font-weight: 600;
		color: var(--md-sys-color-on-surface);
		margin: 0;
	}

	.platform-desc {
		font-size: 13px;
		color: var(--md-sys-color-on-surface-variant);
		margin: 4px 0 0 0;
	}

	.store-buttons {
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.store-buttons > * {
		width: 150px;
	}

	@media (max-width: 768px) {
		.download-row {
			flex-direction: column;
			align-items: stretch;
			gap: 16px;
		}

		.platform-info {
			justify-content: flex-start;
		}

		.store-buttons {
			justify-content: stretch;
		}
	}
</style>

<style is:global>
	#toast-container {
		position: fixed;
		bottom: 16px;
		right: 16px;
		z-index: 9999;
		display: flex;
		flex-direction: column;
		gap: 8px;
		pointer-events: none;
	}

	.toast {
		position: relative;
		background-color: var(--md-sys-color-inverse-surface);
		color: var(--md-sys-color-inverse-on-surface);
		padding: 14px 16px;
		border-radius: 12px;
		font-size: 14px;
		font-weight: 500;
		letter-spacing: 0.1px;
		box-shadow:
			0 1px 2px rgba(0, 0, 0, 0.3),
			0 1px 3px 1px rgba(0, 0, 0, 0.15);
		opacity: 0;
		transform: translateY(8px) scale(0.95);
		transition:
			opacity 200ms cubic-bezier(0.2, 0, 0, 1),
			transform 200ms cubic-bezier(0.2, 0, 0, 1);
		pointer-events: auto;
		min-width: 180px;
		max-width: 320px;
		text-align: center;
		overflow: hidden;
	}

	.toast.show {
		opacity: 1;
		transform: translateY(0) scale(1);
	}

	.toast-progress {
		position: absolute;
		bottom: 0;
		left: 0;
		height: 3px;
		width: 100%;
		background-color: var(--md-sys-color-primary);
		transform-origin: left;
		animation: toast-progress 3s linear forwards;
		border-radius: 0 0 12px 12px;
	}

	@keyframes toast-progress {
		from {
			transform: scaleX(1);
		}
		to {
			transform: scaleX(0);
		}
	}

	@media (max-width: 480px) {
		#toast-container {
			left: 16px;
			right: 16px;
			bottom: 16px;
		}

		.toast {
			max-width: none;
			width: 100%;
		}
	}
</style>
