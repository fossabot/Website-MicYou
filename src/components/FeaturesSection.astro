---
import FeatureCard from "./FeatureCard.astro";

interface Props {
	t: {
		title: string;
		subtitle: string;
		latencyTitle: string;
		latencyDesc: string;
		qualityTitle: string;
		qualityDesc: string;
		connectionTitle: string;
		connectionDesc: string;
		crossPlayTitle: string;
		crossPlayDesc: string;
		setupTitle: string;
		setupDesc: string;
		privacyTitle: string;
		privacyDesc: string;
	};
}

const { t } = Astro.props;

const features = [
	{ icon: "speed", title: t.latencyTitle, description: t.latencyDesc },
	{
		icon: "mic_external_on",
		title: t.qualityTitle,
		description: t.qualityDesc,
	},
	{
		icon: "wifi_tethering",
		title: t.connectionTitle,
		description: t.connectionDesc,
	},
	{ icon: "devices", title: t.crossPlayTitle, description: t.crossPlayDesc },
	{
		icon: "settings_input_component",
		title: t.setupTitle,
		description: t.setupDesc,
	},
	{ icon: "security", title: t.privacyTitle, description: t.privacyDesc },
];
---

<section id="features" class="features-section">
	<div class="features-header">
		<h2 class="features-title">{t.title}</h2>
		<p class="features-subtitle">{t.subtitle}</p>
	</div>

	<div class="features-grid">
		{
			features.map((feature, index) => (
				<FeatureCard
					icon={feature.icon}
					title={feature.title}
					description={feature.description}
					delay={index * 100}
				/>
			))
		}
	</div>
</section>

<style>
	.features-section {
		padding: 100px 24px;
		background-color: var(--md-sys-color-background);
		max-width: 1200px;
		margin: 0 auto;
	}

	.features-header {
		text-align: center;
		margin-bottom: 64px;
	}

	.features-title {
		font-family: "Roboto", sans-serif;
		font-size: 36px;
		font-weight: 700;
		color: var(--md-sys-color-on-surface);
		margin-bottom: 16px;
	}

	.features-subtitle {
		font-size: 18px;
		color: var(--md-sys-color-on-surface-variant);
		max-width: 600px;
		margin: 0 auto;
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 24px;
	}
</style>
