---
import Layout from "../layouts/Layout.astro";
import NavBar from "../components/NavBar.astro";
import HeroSection from "../components/HeroSection.astro";
import FeaturesSection from "../components/FeaturesSection.astro";
import DownloadSection from "../components/DownloadSection.astro";
import ContributorsSection from "../components/ContributorsSection.astro";
import Footer from "../components/Footer.astro";
import zh from "../locales/zh";
import "../styles/theme.css";
---

<Layout
	title="MicYou"
	description="MicYou - 将手机变成专业麦克风。"
	lang="zh"
>
	<NavBar t={zh.nav} currentLang="zh" />
	<main>
		<HeroSection t={zh.hero} />
		<FeaturesSection t={zh.features} />
		<DownloadSection t={zh.download} />
		<ContributorsSection t={zh.contributors} />
	</main>
	<Footer t={zh.footer} />
</Layout>
